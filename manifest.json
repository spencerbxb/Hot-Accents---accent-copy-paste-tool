{
  "name": "Hot Accents",
  "description": "Quickly access accents within your current browser tab!",
  "version": "1.1",
  "manifest_version": 3,
  "icons": {
    "16": "icons/logo16.png",
    "48": "icons/logo48.png",
    "128": "icons/logo128.png"
  },
  "action": {
    "default_popup": "accents.html",
    "default_icon": {
      "16": "icons/logo16.png",
      "48": "icons/logo48.png",
      "128": "icons/logo128.png"
    }
  }
}